<% layout ("layouts/boilerplate") %>

<div class="container my-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="text-primary-dark mb-0">Items Management</h1>
    <a href="/owner/new" class="btn btn-primary">Add New Item</a>
  </div>
  <hr>

  <div class="row g-4">
    <% for (item of items) {%>
      <div class="col-xl-4 col-lg-6 col-12">
        <div class="owner-card">
          <div class="row g-0">
            <div class="col-md-5">
              <img src="<%= item.image %>" class="img-fluid rounded-start h-100" alt="<%= item.name %>" style="object-fit: cover;">
            </div>
            <div class="col-md-7">
              <div class="card-body h-100 d-flex flex-column">
                <h5 class="card-title text-primary-dark"><%= item.name %></h5>
                <p class="card-text flex-grow-1"><%= item.description %></p>

                <% if(!item.isDiscount) { %>
                  <h4 class="text-primary-dark mb-3">₹<%= item.price %></h4>
                <% } else { %>
                  <div class="mb-2">
                    <span class="price-original">₹<%= item.price %></span>
                    <span class="badge bg-danger ms-2"><%= item.percent_discount %>% OFF</span>
                  </div>
                  <h4 class="price-discounted mb-3">₹<%= Math.round(item.price - (item.price/100)*item.percent_discount) %></h4>
                <% } %>

                <div class="owner-actions mt-auto">
                  <form action="/owner/edit/<%= item.id %>" class="d-inline">
                    <button class="btn btn-secondary">Edit</button>
                  </form>
                  <form method="post" action="/owner/delete/<%= item.id %>?_method=DELETE" class="d-inline">
                    <button class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this item?')">Delete</button>
                  </form>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% } %>
  </div>

  <% if (items && items.length === 0) { %>
    <div class="text-center mt-5">
      <h3 class="text-muted">No items found</h3>
      <p class="text-muted">Start by adding your first item!</p>
      <a href="/owner/new" class="btn btn-primary">Add New Item</a>
    </div>
  <% } %>
</div>