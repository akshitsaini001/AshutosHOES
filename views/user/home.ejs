<% layout ("layouts/boilerplate") %>

<!-- Hero Section -->
<div class="container-fluid my-4">
    <div class="hero">
        <div class="hero-content">
            <div class="row h-100 align-items-center">
                <div class="col-lg-6 col-md-8 col-12">
                    <h1 class="display-4 fw-bold mb-4">ENGINEERED FOR THE URBAN FRONTIER.</h1>
                    <h2 class="h3 mb-4">THE 'ROXX' COLLECTION.</h2>
                    <button class="btn btn-primary btn-lg">SHOP NOW</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Shopping Section -->
<section class="container my-5">
    <h2 class="text-center mb-5 text-primary-dark">Featured Products</h2>
    <div class="row g-4">
        <% for(item of items){ %>
            <div class="col-xl-3 col-lg-4 col-md-6 col-12">
                <div class="card h-100">
                    <img src="<%= item.image %>" class="card-img-top" alt="<%= item.name %>">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title"><%= item.name %></h5>
                        <p class="card-text flex-grow-1"><%= item.description %></p>

                        <% if(!item.isDiscount) { %>
                            <h4 class="text-primary-dark mb-3">₹<%= item.price %></h4>
                        <% } else { %>
                            <div class="mb-2">
                                <span class="price-original">₹<%= item.price %></span>
                                <span class="badge bg-danger ms-2"><%= item.percent_discount %>% OFF</span>
                            </div>
                            <h4 class="price-discounted mb-3">₹<%= Math.round(item.price - (item.price/100)*item.percent_discount) %></h4>
                        <% } %>

                        <form action="" class="mt-auto">
                            <button class="btn btn-primary w-100">ADD TO CART</button>
                        </form>
                    </div>
                </div>
            </div>
        <% } %>
    </div>
</section>